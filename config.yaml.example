# SSV Oracle Configuration Example
# Copy this file to config.yaml and update values for your environment.

# ============================================================================
# Ethereum & Beacon Chain
# ============================================================================

# Ethereum Execution Layer RPC endpoint (HTTP - for transactions and queries)
eth_rpc: "http://127.0.0.1:8545"

# Ethereum Execution Layer WebSocket endpoint (for event subscriptions)
# Required if running with --updater flag
eth_ws_rpc: "ws://127.0.0.1:8546"

# Beacon Chain (Consensus Layer) API endpoint (for effective balances and finalization)
beacon_rpc: "http://127.0.0.1:5052"

# ============================================================================
# Contract
# ============================================================================

# SSV Network contract address (includes oracle functionality)
ssv_contract: "0x..."

# ============================================================================
# Event Syncing Configuration
# ============================================================================

# Block number when SSV contract was deployed (start syncing from here)
sync_from_block: 0

# Blocks to process per batch (smaller = faster progress updates)
sync_batch_size: 1000

# Max retry attempts for RPC failures
sync_max_retries: 3

# ============================================================================
# Database Configuration
# ============================================================================

# PostgreSQL connection
db_host: "localhost"
db_port: 5432
db_name: "ssv_oracle"
db_user: "oracle"
db_password_env: "DB_PASSWORD"  # Read password from this environment variable

# ============================================================================
# Wallet Configuration
# ============================================================================

wallet:
  type: "env"  # env | keystore
  private_key_env: "PRIVATE_KEY"
  # keystore_path: "/path/to/keystore.json"
  # password_env: "KEYSTORE_PASSWORD"
  # password_file: "/path/to/password.txt"

# ============================================================================
# Transaction Policy
# ============================================================================

# Controls gas estimation, retries, bumping, and cancellation
tx_policy:
  gas_buffer_percent: 20        # Add 20% to estimated gas to prevent out-of-gas
  max_fee_per_gas: "100 gwei"   # Never exceed this gas price
  pending_timeout_blocks: 10    # Blocks to wait before bumping gas
  gas_bump_percent: 10          # Minimum 10% bump for replace-by-fee
  max_retries: 3                # Retry attempts before cancellation
  retry_delay: 5s               # Delay between retries

# ============================================================================
# Commit Phases
# ============================================================================

# Phases define when oracle commits happen. Each has start_epoch and interval.
# Multiple phases allow changing interval over time (must be sorted by start_epoch).
commit_phases:
  - start_epoch: 0  # First epoch where oracle should commit
    interval: 225   # Commit every 225 epochs
