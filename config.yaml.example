# SSV Oracle Configuration
# Copy to config.yaml and update for your environment.

# ============================================================================
# Ethereum & Beacon Chain
# ============================================================================

eth_rpc: "http://127.0.0.1:8545"       # Execution layer (HTTP)
eth_ws_rpc: "ws://127.0.0.1:8546"      # Execution layer (WebSocket, required for --updater)
beacon_rpc: "http://127.0.0.1:5052"    # Consensus layer

# ============================================================================
# Contract
# ============================================================================

ssv_contract: "0x..."

# ============================================================================
# Database
# ============================================================================

db_host: "localhost"
db_port: 5432
db_name: "ssv_oracle"
db_user: "oracle"
db_password_env: "DB_PASSWORD"         # Read password from this env var

# ============================================================================
# Event Syncing
# ============================================================================

sync_from_block: 0                     # Block when SSV contract was deployed
sync_batch_size: 1000                  # Blocks per batch
sync_max_retries: 3                    # Max RPC retry attempts

# ============================================================================
# Wallet
# ============================================================================

wallet:
  type: "env"                          # env | keystore
  private_key_env: "PRIVATE_KEY"
  # keystore_path: "/path/to/keystore.json"
  # password_env: "KEYSTORE_PASSWORD"
  # password_file: "/path/to/password.txt"

# ============================================================================
# Transaction Policy
# ============================================================================

tx_policy:
  gas_buffer_percent: 20               # Added to gas estimates
  max_fee_per_gas: "100 gwei"          # Hard cap on gas price
  pending_timeout_blocks: 10           # Blocks before bumping
  gas_bump_percent: 10                 # Min bump for replace-by-fee
  max_retries: 3                       # Attempts before cancellation
  retry_delay: 5s

# ============================================================================
# Commit Phases
# ============================================================================

# Phases define commit schedule. Multiple phases allow changing interval over time.
commit_phases:
  - start_epoch: 0                     # First epoch to commit
    interval: 225                      # Commit every N epochs
