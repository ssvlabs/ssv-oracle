# SSV Oracle Environment Variables
# Copy this to .env and fill in your values:
#   cp .env.example .env

# Database password (matches docker-compose.yaml)
DB_PASSWORD=oracle123

# Private key for signing transactions (with or without 0x prefix)
# IMPORTANT: Replace with your own key! Generate one with: cast wallet new
PRIVATE_KEY=your_private_key_here

# Logging configuration
# LOG_LEVEL: debug, info, warn, error (default: info in production, debug in dev)
LOG_LEVEL=info

# DEV: Set to "true" for development mode (colored console output, debug level by default)
# DEV=true
